# Option 1: Full database URL (takes priority)
# DATABASE_URL=mysql+pymysql://root:yourpassword@localhost:3306/simplystocked

# Option 2: Individual DB vars (used if DATABASE_URL is not set)
DB_PASSWORD=yourpassword
DB_USER=root
DB_HOST=localhost
DB_PORT=3306
DB_NAME=simplystocked

# CORS — comma-separated origins
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Set to "true" to log all SQL queries (development only)
SQL_ECHO=false

# Google OAuth client ID (for Google sign-in)
GOOGLE_CLIENT_ID=
