{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Firebase Auth UID" },
        "name": { "type": "string", "description": "Display name" },
        "email": { "type": "string", "format": "email", "description": "User email" },
        "role": { "type": "string", "enum": ["admin", "user", "guest"], "description": "User role" },
        "avatarUrl": { "type": "string", "description": "Profile picture URL" },
        "studentPid": { "type": "string", "description": "Optional student PID" }
      },
      "required": ["id", "name", "email", "role"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "User profile documents"
    }
  }
}
